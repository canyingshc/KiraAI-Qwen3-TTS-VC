      },
      "ws_url": {
        "name": "WebSocket URL",
        "type": "string",
        "default": "wss://dashscope.aliyuncs.com/api-ws/v1/realtime",
        "hint": "Beijing: wss://dashscope.aliyuncs.com/api-ws/v1/realtime | Singapore: wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime"
      },
      "timeout": {
        "name": "Timeout",
        "type": "integer",
        "default": 120,
        "min": 1,
        "hint": "Max seconds for TTS synthesis"
      }
    }
  }

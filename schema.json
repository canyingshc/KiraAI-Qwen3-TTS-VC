{
  "provider_config": {
    "api_key": {
      "name": "Dashscope API Key",
      "type": "sensitive",
      "default": null,
      "hint": "Your Dashscope / Alibaba Cloud API Key"
    }
  },
  "model_config": {
    "tts": {
      "voice_id": {
        "name": "Voice ID",
        "type": "string",
